# --- OpenAI ---
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o
VISION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.0

# --- Storage ---
CHROMA_DIR=./data/chroma_db
UPLOAD_DIR=./data/uploads
COLLECTION_NAME=rag_documents

# --- Retrieval / reranking ---
RETRIEVE_K=20
RERANK_N=5
BM25_WEIGHT=0.5
DENSE_WEIGHT=0.5
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Vision / OCR ---
ENABLE_VISION=true
ENABLE_OCR=true
SCANNED_TEXT_THRESHOLD=50

# --- Optional Cohere reranker ---
# COHERE_API_KEY=...
